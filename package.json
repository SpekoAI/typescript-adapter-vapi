{
  "name": "@spekoai/adapter-vapi",
  "version": "0.0.0",
  "description": "Vapi adapter for Speko — point Vapi at Speko's router instead of single providers",
  "license": "MIT",
  "author": "Speko",
  "homepage": "https://github.com/SpekoAI/typescript-adapter-vapi#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SpekoAI/typescript-adapter-vapi.git"
  },
  "bugs": {
    "url": "https://github.com/SpekoAI/typescript-adapter-vapi/issues"
  },
  "keywords": ["speko", "vapi", "voice-ai", "adapter"],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": ["dist", "README.md", "LICENSE"],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@spekoai/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  }
}
